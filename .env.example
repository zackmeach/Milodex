# Copy this file to .env (gitignored — never commit real keys; keep .env local and
# user-readable only) and fill in the values below.

# Alpaca API credentials
# Get your keys at: https://app.alpaca.markets/
ALPACA_API_KEY=your_api_key_here
ALPACA_SECRET_KEY=your_secret_key_here

# Trading mode: "paper" or "live"
# Always start with paper. Live requires manual promotion.
TRADING_MODE=paper
