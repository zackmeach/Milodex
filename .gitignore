# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
dist/
build/
*.whl
.eggs/

# Virtual environments
.venv/
venv/
ENV/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# Claude Code local settings
.claude/

# Secrets and environment
.env
*.pem
*.key

# OS
.DS_Store
Thumbs.db

# Testing / Coverage
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/

# Logs (keep the directory, ignore contents)
logs/*
!logs/.gitkeep

# Durable Milodex-authoritative state (event store + locks; see ADR 0018)
data/*
!data/.gitkeep

# Shakeout / paper-runtime scratch directories — never commit these
data/paper_runtime_*/

# Ad-hoc DB backup snapshots — never commit these
data/*.backup-*

# Ruff
.ruff_cache/

# Market data cache (local Parquet files)
market_cache/

# Mutation testing (mutmut) — discovery artifacts; do not commit
.mutmut-cache
.mutmut-cache*
.mutmut-cache/
.mutmut-*.log
.mutmut-*.db
mutants/
html/
.superpowers/
/docs/prototypes/

# PyInstaller build outputs (ADR 0037) — installer/ source stays in git;
# only the build-time artifacts produced by build_installer.ps1 are ignored.
/build/
/dist/
*.spec.bak
